# 默认汇率（USD to CNY），无汇率文件时使用
DEFAULT_EXCHANGE_RATE=7.0288

# 汇率 CSV 文件路径（可选，默认 output/exchange_rates.csv）
EXCHANGE_RATE_FILE=

# ============================================================
# PDF 月结单密码（必填，否则导入时会报错）
# 请替换为你自己的券商月结单密码
# ============================================================

# 长桥（Longbridge）PDF 月结单密码
LONGBRIDGE_PASSWORD=YOUR_PASSWORD_HERE

# 富途（Futu）PDF 月结单密码（2024 年及以前的月结单需要）
FUTU_2024_PASSWORD=YOUR_PASSWORD_HERE
